  "scaling_factors": {
    "_baseline": "All multipliers are relative to: age 30 / sum_insured Rs 5,00,000 / city_tier metro / non-smoker / family_size 1 (individual). The reference base premium across mainstream insurers at this profile is approximately Rs 5,000-6,500/yr in 2026 (e.g., HDFC Optima Secure Rs 4,800; Care Supreme Rs 4,800; Tata AIG MediCare Premier Rs 8,362).",
    "age_multipliers": {
      "18-25": 0.85,
      "26-35": 1.0,
      "36-45": 1.4,
      "46-55": 2.1,
      "56-65": 3.2,
      "66-75": 4.5,
      "75+": 5.8
    },
    "_age_source": "Derived from Tata AIG MediCare Premier official rate chart (19-35 / 5L = Rs 8,362; 36-45 / 5L = Rs 9,868 => 1.18x for that band, but the 46-55 band step is steep). Cross-checked against JoinDitto's HDFC Ergo Optima Secure and Niva Bupa ReAssure 2.0 published bands. Senior bands (56+) verified against Star Red Carpet and Bajaj Silver Health.",
    "sum_insured_multipliers": {
      "300000": 0.82,
      "500000": 1.0,
      "1000000": 1.35,
      "1500000": 1.65,
      "2500000": 2.25,
      "5000000": 3.2,
      "10000000": 4.8
    },
    "_si_source": "Derived from Tata AIG MediCare Premier rate chart (5L = Rs 8,362; 10L = Rs 10,319 => 1.234x) and HDFC Optima Secure (5L Rs 4,800; 10L Rs 6,492 => 1.35x). 1.35x is the rounder average used here. Premium grows sub-linearly with SI because the catastrophic-tail probability is roughly log-linear in SI.",
    "city_tier_multipliers": {
      "metro": 1.0,
      "tier1": 0.92,
      "tier2": 0.82
    },
    "_city_source": "Derived from Star Health zone-wise rate chart (Zone A vs B vs C) and Care/HDFC tier pricing differential mentioned across PolicyBazaar listings. Most insurers use 3 zones: Zone A (metros) ~ 1.00x, Zone B (tier-1) ~ 0.90-0.93x, Zone C (smaller cities) ~ 0.80-0.85x.",
    "smoker_multiplier": 1.25,
    "_smoker_source": "Acko, PolicyBazaar smoker articles: typical loading 15-25% for declared regular smokers; some insurers go up to 30-40% for heavy smokers (>10 cigs/day). 1.25x chosen as mid-point for the bot's typical conservative quote.",
    "family_floater_multipliers": {
      "1": 1.0,
      "2": 1.65,
      "3": 2.0,
      "4": 2.4,
      "5": 2.7,
      "6": 2.95
    },
    "_floater_source": "Derived from comparison of individual vs 1A+1C, 2A+0C, 2A+1C, 2A+2C rates in Star Family Health Optima Annexure-2 and Niva Bupa Health Premia rate card. A family floater for 4 is ~2.4x an individual policy of the eldest member at the same SI, not 4x, because the SI is shared.",
    "_combined_example": "30-year-old non-smoker in metro, 10L SI, family floater for 4: base ~Rs 5,500 (HDFC anchor) * age 1.0 * SI 1.35 * city 1.0 * smoker 1.0 * floater 2.4 = ~Rs 17,820/year. Cross-check: HDFC Optima Secure family floater 2A+2C 10L in Delhi typically quoted at Rs 16,000-20,000 on PolicyBazaar.",
    "rounding": "All computed premiums should be rounded to nearest Rs 100 when surfaced to the user. Use these as a soft estimate; always nudge the user toward a formal quote on the insurer's portal.",
    "ped_specialty_load": {
      "diabetes_or_hypertension_day1": 1.35,
      "_source": "Acko + PolicyBazaar published comparisons of PED-specialty vs base health plans 2024; range 30-40%, median 35%"
    },
    "group_plan_discount": {
      "group_b2b": 0.6,
      "_source": "Cafemutual + IRDAI group health filings; group rates typically 50-70% of individual"
    }
  }
}